# Flask / Runtime
DEBUG=True
HOST=0.0.0.0
PORT=5000
SECRET_KEY=replace_with_a_long_random_secret
JWT_SECRET_KEY=replace_with_a_different_long_random_secret

# Database
MONGO_URI=mongodb://localhost:27017/threattrace

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PUBLIC_URL=http://127.0.0.1:5000

# Email (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Socket / workers
SOCKET_CHANNEL=alerts
SOCKET_ASYNC_MODE=eventlet
